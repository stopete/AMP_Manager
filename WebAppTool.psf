  <Code><![CDATA[
$formWebAppTool_Load={
	#TODO: Initialize Form Controls here
	
	#Obtaining the Current Working Directory using PowerShell
	$workingdirectory = [System.AppDomain]::CurrentDomain.BaseDirectory.TrimEnd('\')
	if ($workingdirectory -eq $PSHOME.TrimEnd('\'))
	{
		$workingdirectory = $PSScriptRoot
		
	}
		
	# working directory
	$mypath = $workingdirectory
	
	# Import apps path settings from config file
	[xml]$global:ConfigFile = Get-Content $mypath"\Settings.xml"
	
	# Define Variables
	$Global:PHPpath = $ConfigFile.Settings.PathSettings.PHPpath
	$global:Apachepath = $ConfigFile.Settings.PathSettings.Apachepath;
	$global:MySQLpath = $ConfigFile.Settings.PathSettings.MySQLpath
	$global:OpenSSLpath = $ConfigFile.Settings.PathSettings.OpenSSLpath
	$global:MSQLService = $ConfigFile.Settings.ServiceName.ServiceMySQL;
	$global:ApacheService = $ConfigFile.Settings.ServiceName.ServiceApache;
	
	function global:webappsinfo
	{
		
		# Checks if Apache path doesnt not exist else will get Apache syntax, version, openssl version 
		# and Apache service status.
		if (-not (Test-Path -path $Apachepath -PathType Leaf))
		{
						
			Write-host "The Apache path on the connfig file doesn't exist on the Server." -ForegroundColor DarkGreen
			
			Write-host ""
			
					}
		else
		{
			# check Apache syntax on config file
			Write-host "Apache config syntax status:" -ForegroundColor DarkGreen
			
			$syntax = & $Apachepath -t 2>&1 | %{ "$_" }
			
			Write-Host $syntax
			
			Write-host ""
			
			# check Apache Version
			write-host "Apache version:" -ForegroundColor DarkGreen
			
			$apacheversion = & $Apachepath -v 2>&1 | %{ "$_" }
			
			Write-Host $apacheversion
			
			write-host ""
			# Check OpenSSL version
			
			write-host "OpenSSL version:" -ForegroundColor DarkGreen
			
			$OpenSSLVer = & $OpenSSLpath version 2>&1 | %{ "$_" }
			
			Write-Host $OpenSSLVer
			
			Write-host ""
			
			#Check Apache service
			Write-host "Apache service status:" -ForegroundColor DarkGreen
			
			$ApacheStatus = (Get-Service -Name $ApacheService).Status
			
			Write-Host $ApacheStatus
			
			Write-host ""
		}
		
		# Checks if PHP paht exist else will output PHP version
		if (-not (Test-Path -path $PHPpath -PathType Leaf))
		{
			# file with path $path doesn't exist
			
			Write-host "The PHP path on the connfig file doesn't exist on the Server." -ForegroundColor DarkGreen
			
			Write-host ""
		}
		else
		{
			# Check PHP version
			Write-host "PHP version:" -ForegroundColor DarkGreen
			
			$PHPver = & $PHPpath -version
			
			Write-Host $PHPver
			
			Write-Host ""
			
		}
		
		
		# Check if MySQL path exist else get MySQL version and service status
		if (-not (Test-Path -path $MySQLpath -PathType Leaf))
		{
			# file with path $path doesn't exist
			
			Write-host "The MySQL path on the connfig file doesn't exist on the Server." -ForegroundColor DarkGreen
			
			Write-host ""
			
		}
		else
		{
			# Check MySQL version
			$mysqlver = & $MySQLpath --% --version
			
			Write-Host "MySQL version:" -ForegroundColor DarkGreen
			
			Write-Host $mysqlver
			
			write-host ""
			
			# Check MySQL service status
			$GetStatus = (get-service -Name $MSQLService).Status
			
			Write-Host "MySQL status:" -ForegroundColor DarkGreen
			
			Write-Host $GetStatus
			
			Write-Host ""
			
			Write-Host ""
			
		}
		
	}
	
	# call function
	webappsinfo
	
}

#region Control Helper Functions
function Update-ComboBox
{
<#
	.SYNOPSIS
		This functions helps you load items into a ComboBox.
	
	.DESCRIPTION
		Use this function to dynamically load items into the ComboBox control.
	
	.PARAMETER ComboBox
		The ComboBox control you want to add items to.
	
	.PARAMETER Items
		The object or objects you wish to load into the ComboBox's Items collection.
	
	.PARAMETER DisplayMember
		Indicates the property to display for the items in this control.
		
	.PARAMETER ValueMember
		Indicates the property to use for the value of the control.
	
	.PARAMETER Append
		Adds the item(s) to the ComboBox without clearing the Items collection.
	
	.EXAMPLE
		Update-ComboBox $combobox1 "Red", "White", "Blue"
	
	.EXAMPLE
		Update-ComboBox $combobox1 "Red" -Append
		Update-ComboBox $combobox1 "White" -Append
		Update-ComboBox $combobox1 "Blue" -Append
	
	.EXAMPLE
		Update-ComboBox $combobox1 (Get-Process) "ProcessName"
	
	.NOTES
		Additional information about the function.
#>
	
	param
	(
		[Parameter(Mandatory = $true)]
		[ValidateNotNull()]
		[System.Windows.Forms.ComboBox]
		$ComboBox,
		[Parameter(Mandatory = $true)]
		[ValidateNotNull()]
		$Items,
		[Parameter(Mandatory = $false)]
		[string]$DisplayMember,
		[Parameter(Mandatory = $false)]
		[string]$ValueMember,
		[switch]
		$Append
	)
	
	if (-not $Append)
	{
		$ComboBox.Items.Clear()
	}
	
	if ($Items -is [Object[]])
	{
		$ComboBox.Items.AddRange($Items)
	}
	elseif ($Items -is [System.Collections.IEnumerable])
	{
		$ComboBox.BeginUpdate()
		foreach ($obj in $Items)
		{
			$ComboBox.Items.Add($obj)
		}
		$ComboBox.EndUpdate()
	}
	else
	{
		$ComboBox.Items.Add($Items)
	}
	
	if ($DisplayMember)
	{
		$ComboBox.DisplayMember = $DisplayMember
	}
	
	if ($ValueMember)
	{
		$ComboBox.ValueMember = $ValueMember
	}
}

#endregion

# Get service current status
function Getservicestatus  ($servicename)
{
	$status = (get-service -Name $servicename).Status
	
	if ($status -eq "Running")
	{
		return $true;
	}
	else
	{
		return $false;
	}
	
}

# Re-start service
function restartservice ($servicename)
{
	
	get-service -Name $servicename | Restart-Service
	
	$GetStatus = (get-service -Name $servicename).Status
	
	write-host "$servicename status $GetStatus"
	Write-host
	
}

# Stop service
function stopservice ($servicename)
{
	
	if (Getservicestatus $servicename)
	{
		Write-Host "Stopping $servicename service..."
		get-service -Name $servicename | Stop-Service
		
		$GetStatus = (get-service -Name $servicename).Status
		
		write-host "$servicename status $GetStatus"
		Write-host
		
	}
	else
	{
		
		$GetStatus = (get-service -Name $servicename).Status
		Write-host "$servicename status $GetStatus"
		Write-Host ""
	}
	
}

# Start service
function startservice ($servicename)
{
	
	if (!(Getservicestatus $servicename))
	{
		Write-Host "Starting $servicename service..."
		get-service -Name $servicename | Start-Service
		$GetStatus = (get-service -Name $servicename).Status
		write-host "$servicename status $GetStatus"
		
		Write-host
		
	}
	else
	{
		
		$GetStatus = (get-service -Name $servicename).Status
		Write-host "$servicename status $GetStatus"
		
	}
	
}
# Open httpd.conf file for editing
function openhttpd
{
		
	# Full path of the file
	$file = 'C:\Program Files\Notepad++\notepad++.exe'
	
	#If the file does not exist, create it.
	if (Test-Path -Path $file -PathType Leaf)
	{
		
		& $file "c:\Apache24\conf\httpd.conf"
	}
	else
	{
		
		& Notepad.exe "c:\Apache24\conf\httpd.conf"
	}
	
	
}

# Open httpd-vhost.conf file for editing
function openvhost
{
	
	# Full path of the file
	$file = 'C:\Program Files\Notepad++\notepad++.exe'
	
	# Open file for editing
	if (Test-Path -Path $file -PathType Leaf)
	{
		
		& $file "C:\Apache24\conf\extra\httpd-vhosts.conf"
	}
	else
	{
		
		& Notepad.exe "C:\Apache24\conf\extra\httpd-vhosts.conf"
	}
	
}

function openphpini
{
	
	# Full path of the file
	$file = 'C:\Program Files\Notepad++\notepad++.exe'
	
	# Open file for editing
	if (Test-Path -Path $file -PathType Leaf)
	{
		
		& $file "C:\php\php.ini"
	}
	else
	{
		
		& Notepad.exe "C:\php\conf\php.ini"
	}
		
}

$buttonGo_Click={
	#TODO: Place custom script here
	
	# The variable holds the item selected in the drop donw menue on the combobox
	$option = $combobox1.SelectedItem
	
	switch ($option)
	{
		"Re-Start http"
		{
			Write-Host "Re-staring Apache service..."
			restartservice $ApacheService
			
			
		}
		"Stop http"
		{
			stopservice $ApacheService
			
		}
		"Start http"
		{
			startservice $ApacheService
		}
		"Open httpd.conf"
		{
			openhttpd
		}
		"Open Vhost"
		{
			openvhost
		}
		"Open php.ini"
		{
			openphpini
			
		}
		"Re-Start msql"
		{
			restartservice $MSQLService
			
		}
		"Stop msql"
		{
			stopservice $MSQLService
			
		}
		"Start msql"
		{
			startservice $MSQLService
			
		}
		
		"Display Web Apps Info"
		{
			
			webappsinfo
			
		}
		
		default { Write-Host "Please pick on option from the the dropsown list."}
	}
		
}


